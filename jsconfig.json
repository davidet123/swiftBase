{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "preserve",
    "checkJs": false,
    "lib": ["ESNext", "Dom", "Dom.Iterable"]
  },
  "exclude": ["node_modules", "dist"]
}

